# AmiVoice ACP2 APIキー
AMIVOICE_APP_KEY=your_amivoice_app_key_here

# AmiVoice WebSocket サーバ URL（省略時: wss://acp-api.amivoice.com/v1/recognize）
# AMIVOICE_SERVER_URL=wss://acp-api.amivoice.com/v1/recognize

# 音声コーデック（省略時: LSB16K）
# AMIVOICE_CODEC=LSB16K

# グラマファイル名（省略時: -a-general）
# AMIVOICE_GRAMMAR=-a-general

# Google Gemini APIキー
GEMINI_API_KEY=your_gemini_api_key_here

# Geminiモデル名（省略時: gemini-2.5-flash-lite）
GEMINI_MODEL=gemini-2.5-flash-lite

# RTL-SDR / rtl_fm（省略可）
# FM_BANDWIDTH=25k      # NBFM帯域: 12.5k / 25k
# RTL_GAIN=0            # ゲイン（0=自動）
# RTL_PPM=0             # PPM補正（周波数ズレがある場合）
